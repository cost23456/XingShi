  m_Name: "NPC\u5BF9\u8BDD_\u8001\u5E08"
  m_EditorClassIdentifier: 
  dialogueLines:
  - content: "\u674E\u8001\u5E08\uFF08\u8D70\u8FD1\uFF0C\u8E72\u4E0B\uFF09\uFF1A\u600E\u4E48\u4E86\uFF1F  "
  - content: "\u9648\u8DEF\uFF08\u54FD\u54BD\uFF09\uFF1A\u6211\u5988\u8BF4\u4E0B\u4E2A\u5B66\u671F\u4E0D\u4E0A\u4E86\u3002\u5BB6\u91CC\u6CA1\u94B1\u3002  "
  - content: "\u674E\u8001\u5E08\uFF08\u6C89\u9ED8\u7247\u523B\uFF0C\u6478\u6478\u4ED6\u7684\u5934\uFF09\uFF1A\u597D\u597D\u8BFB\u4E66\u624D\u80FD\u6709\u51FA\u8DEF\uFF0C\u5B66\u8D39\u4E0D\u662F\u4EC0\u4E48\u5927\u4E8B\uFF0C\u8001\u5E08\u5E2E\u4F60\u60F3\u529E\u6CD5\u3002"
